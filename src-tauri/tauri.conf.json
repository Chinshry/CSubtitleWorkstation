{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSubtitleWorkstation",
  "version": "0.1.0",
  "identifier": "com.cbash.csubtitleworkstation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC字幕压制工作站",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "dragDropEnabled": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "resources/avs/*"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://example.com/CSubtitleWorkstation/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
