{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CSubtitleWorkstation",
  "version": "../package.json",
  "identifier": "com.cbash.csubtitleworkstation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC字幕压制工作站",
        "width": 1180,
        "height": 760,
        "minWidth": 820,
        "minHeight": 560,
        "dragDropEnabled": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
